alias cls='clear'
alias disass='objdump -dC -M intel --section=.text'
alias v='nvim'
alias brc='source ~/.bashrc'

# ls
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# git
alias gs='git status'
alias gl='git log --oneline'

